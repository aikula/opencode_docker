#!/bin/bash
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
CONTAINER_NAME="opencode-${PROJECT_NAME}"

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}🚀 OpenCode CLI${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "📁 Проект:      ${GREEN}$PROJECT_NAME${NC}"
echo -e "📂 Директория:  ${BLUE}$PROJECT_DIR${NC}"
echo -e "🐳 Контейнер:   ${GREEN}$CONTAINER_NAME${NC}"
echo ""

if [ -f "$SCRIPT_DIR/.env" ]; then
    set -a; source "$SCRIPT_DIR/.env"; set +a
    echo -e "${GREEN}✅ Конфигурация: $SCRIPT_DIR/.env${NC}"
else
    echo -e "${RED}❌ Файл .env не найден${NC}"; exit 1
fi

echo -e "${BLUE}📋 Провайдер: ${GREEN}${LLM_PROVIDER:-opencode}${NC}"
echo -e "${BLUE}🤖 Модель:    ${GREEN}GLM-4.7-free (Claude-level, FREE)${NC}"

# Проверяем API ключи
HAS_API_KEY=false
if [ -n "$OPENCODE_API_KEY" ] && [ "$OPENCODE_API_KEY" != "your-opencode-zen-api-key-here" ]; then
    HAS_API_KEY=true
    KEY_PREVIEW="${OPENCODE_API_KEY:0:10}...${OPENCODE_API_KEY: -4}"
    echo -e "${BLUE}🔑 OpenCode Zen: ${GREEN}$KEY_PREVIEW${NC}"
fi
if [ -n "$ZAI_API_KEY" ] && [ "$ZAI_API_KEY" != "your-zhipuai-api-key-here" ]; then
    HAS_API_KEY=true
    KEY_PREVIEW="${ZAI_API_KEY:0:10}...${ZAI_API_KEY: -4}"
    echo -e "${BLUE}🔑 ZhipuAI:   ${GREEN}$KEY_PREVIEW${NC}"
fi
if [ -n "$ANTHROPIC_API_KEY" ] && [ "$ANTHROPIC_API_KEY" != "sk-ant-xxxxxxxxxxxxxxxxxxxx" ]; then
    HAS_API_KEY=true
fi
if [ -n "$OPENAI_API_KEY" ] && [ "$OPENAI_API_KEY" != "sk-xxxxxxxxxxxxxxxxxxxx" ]; then
    HAS_API_KEY=true
fi
echo ""

if [ "$HAS_API_KEY" = false ]; then
    AUTH_FILE="$SCRIPT_DIR/data/auth/auth.json"
    if [ ! -f "$AUTH_FILE" ]; then
        echo -e "${YELLOW}⚠️  API ключ не настроен${NC}"
        echo -e "${YELLOW}💡 Получите бесплатный ключ GLM-4.7-free:${NC}"
        echo -e "   1. Зарегистрируйтесь: ${BLUE}https://opencode.ai/docs/zen/${NC}"
        echo -e "   2. Добавьте payment method (требование системы)"
        echo -e "   3. Скопируйте API ключ в .env как OPENCODE_API_KEY"
        echo -e "   4. Или запустите: ${BLUE}opencode auth login${NC} (выберите OpenCode Zen)"
        echo ""
        docker run -it --rm --name "$CONTAINER_NAME-auth" \
            -v "$SCRIPT_DIR/data/auth:/root/.local/share/opencode" \
            ghcr.io/anomalyco/opencode:latest auth login
        echo ""
        echo -e "${GREEN}✅ Перезапустите ./opencode${NC}"; exit 0
    fi
fi

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}Запуск OpenCode с GLM-4.7...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

docker run -it --rm --name "$CONTAINER_NAME" \
    -v "$SCRIPT_DIR/data/auth:/root/.local/share/opencode" \
    -v "$SCRIPT_DIR/data/config:/root/.config/opencode" \
    -v "$SCRIPT_DIR/data/cache:/root/.cache/opencode" \
    -v "$SCRIPT_DIR/data/pip-cache:/root/.cache/pip" \
    -v "$PROJECT_DIR:/workspace" \
    -v "$PROJECT_DIR/.opencode:/workspace/.opencode" \
    -v "$HOME/.ssh:/root/.ssh:ro" -w /workspace \
    -e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
    -e OPENAI_API_KEY="$OPENAI_API_KEY" \
    -e ZAI_API_KEY="$ZAI_API_KEY" \
    -e OPENCODE_API_KEY="$OPENCODE_API_KEY" \
    -e LLM_PROVIDER="${LLM_PROVIDER:-opencode}" \
    -e GH_TOKEN="$GH_TOKEN" \
    -e GIT_AUTHOR_NAME="${GIT_AUTHOR_NAME:-OpenCode}" \
    -e GIT_AUTHOR_EMAIL="${GIT_AUTHOR_EMAIL:-agent@opencode.local}" \
    opencode-python:latest

echo ""
echo -e "${GREEN}✅ Завершено${NC}"
