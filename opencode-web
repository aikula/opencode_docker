#!/bin/bash
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(pwd)"
PROJECT_NAME="$(basename "$PROJECT_DIR")"
CONTAINER_NAME="opencode-web-${PROJECT_NAME}"

GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}🌐 OpenCode Web Interface${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "📁 Проект:      ${GREEN}$PROJECT_NAME${NC}"
echo -e "📂 Директория:  ${BLUE}$PROJECT_DIR${NC}"
echo -e "🐳 Контейнер:   ${GREEN}$CONTAINER_NAME${NC}"
echo ""

if [ -f "$SCRIPT_DIR/.env" ]; then
    set -a; source "$SCRIPT_DIR/.env"; set +a
    echo -e "${GREEN}✅ Конфигурация (скрипты): $SCRIPT_DIR/.env${NC}"
else
    echo -e "${RED}❌ Файл .env не найден в $SCRIPT_DIR${NC}"
    echo -e "${YELLOW}💡 Создайте .env из .env.example:${NC}"
    echo -e "   cp ${SCRIPT_DIR}/.env.example ${SCRIPT_DIR}/.env"
    echo -e "   nano ${SCRIPT_DIR}/.env"
    exit 1
fi

# API ключ опционален - можно добавить позже через opencode auth
if [ -z "$OPENCODE_API_KEY" ] || [ "$OPENCODE_API_KEY" = "your-opencode-zen-api-key-here" ]; then
    echo -e "${YELLOW}⚠️  OPENCODE_API_KEY не настроен - добавьте позже через 'opencode auth'${NC}"
fi

# Use configurable port
SERVER_PORT="${OPENCODE_SERVER_PORT:-7777}"

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}🌐 Веб-интерфейс запускается...${NC}"
echo ""
echo -e "   URL:    ${BLUE}http://0.0.0.0:${SERVER_PORT}${NC}"
echo -e "   Извне: ${BLUE}http://$(hostname -I | awk '{print $1}'):${SERVER_PORT}${NC}"
echo -e "   Логин:  ${GREEN}opencode${NC}"
echo -e "   Пароль: ${GREEN}${OPENCODE_SERVER_PASSWORD:-me482482}${NC}"
echo ""
echo -e "${YELLOW}Нажмите Ctrl+C для остановки${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""

DETACH=""
if [ "$1" = "-d" ] || [ "$1" = "--detach" ]; then
    DETACH="-d"
    IT_FLAG=""
    echo -e "${BLUE}Запуск в фоновом режиме...${NC}"
else
    IT_FLAG="-it"
fi

docker run $DETACH $IT_FLAG --rm \
    --name "$CONTAINER_NAME" \
    -p 0.0.0.0:${SERVER_PORT}:${SERVER_PORT} \
    -v "$SCRIPT_DIR/data/auth:/root/.local/share/opencode" \
    -v "$SCRIPT_DIR/data/config:/root/.config/opencode" \
    -v "$SCRIPT_DIR/data/cache:/root/.cache/opencode" \
    -v "$SCRIPT_DIR/data/pip-cache:/root/.cache/pip" \
    -v "$PROJECT_DIR:/workspace" \
    -v "$PROJECT_DIR/.opencode:/workspace/.opencode" \
    -v "$HOME/.ssh:/root/.ssh:ro" \
    -w /workspace \
    -e ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
    -e OPENAI_API_KEY="$OPENAI_API_KEY" \
    -e ZAI_API_KEY="$ZAI_API_KEY" \
    -e OPENCODE_API_KEY="$OPENCODE_API_KEY" \
    -e OPENCODE_SERVER_PASSWORD="${OPENCODE_SERVER_PASSWORD:-your-secure-password-here}" \
    -e LLM_PROVIDER="${LLM_PROVIDER:-opencode}" \
    -e GH_TOKEN="$GH_TOKEN" \
    -e GIT_AUTHOR_NAME="${GIT_AUTHOR_NAME:-OpenCode Agent}" \
    -e GIT_AUTHOR_EMAIL="${GIT_AUTHOR_EMAIL:-agent@opencode.local}" \
    -e DATABASE_URL="${DATABASE_URL:-}" \
    -e POSTGRES_HOST="${POSTGRES_HOST:-}" \
    -e POSTGRES_PORT="${POSTGRES_PORT:-}" \
    -e POSTGRES_USER="${POSTGRES_USER:-}" \
    -e POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-}" \
    -e POSTGRES_DATABASE="${POSTGRES_DATABASE:-}" \
    -e BRAVE_API_KEY="${BRAVE_API_KEY:-}" \
    -e EXA_API_KEY="${EXA_API_KEY:-}" \
    opencode-python:latest web --port ${SERVER_PORT} --hostname 0.0.0.0

if [ ! -z "$DETACH" ]; then
    echo ""
    echo -e "${GREEN}✅ Запущен в фоне${NC}"
    echo -e "   Остановить: ${BLUE}opencode-stop${NC}"
    echo -e "   Логи:       ${BLUE}docker logs -f $CONTAINER_NAME${NC}"
fi
