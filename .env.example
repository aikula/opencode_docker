# ==============================================
# OpenCode Environment Configuration Template
# ==============================================
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env to git!
# ==============================================

# ==============================================
# LLM Provider Configuration
# ==============================================
# OpenCode Zen - official OpenCode provider with free models
# GLM-4.7-free: FREE model (Claude/GPT level)
# Get your key: https://opencode.ai/docs/zen/
# NOTE: Free model requires adding payment method in Zen
LLM_PROVIDER=opencode

# ==============================================
# OpenCode Zen API Configuration
# ==============================================
# Get API key: https://opencode.ai/docs/zen/
# GLM-4.7-free: FREE, 200K context, excellent for coding
# Requires Zen registration and payment method on file
OPENCODE_API_KEY=your-opencode-zen-api-key-here

# ==============================================
# Alternative Providers (optional)
# ==============================================
# For direct provider connections (outside Zen):
# ZAI_API_KEY=your-zhipuai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# GOOGLE_API_KEY=your-key-here

# ==============================================
# Web Interface (optional)
# ==============================================
# Password for web interface
# Generate: openssl rand -base64 16
OPENCODE_SERVER_PASSWORD=your-secure-random-password-here

# ==============================================
# Git Configuration (optional)
# ==============================================
# Create token: https://github.com/settings/tokens
# Required scopes: repo, read:org
GH_TOKEN=ghp_your_token_here
GIT_AUTHOR_NAME=Your Name
GIT_AUTHOR_EMAIL=your.email@example.com

# ==============================================
# Logging & Debug
# ==============================================
LOG_LEVEL=info
DEBUG=false

# ==============================================
# MCP Server Configuration
# ==============================================
# PostgreSQL MCP (optional - enables postgres MCP server)
# Get connection string from your database provider
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# PostgreSQL (alternative connection format)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=mydb

# Brave Search MCP (optional - get key at https://search.brave.com/api/)
BRAVE_API_KEY=your_brave_api_key_here

# Exa Search MCP (optional - get key at https://exa.ai)
EXA_API_KEY=your_exa_api_key_here

# ==============================================
# OpenCode Server Settings
# ==============================================
OPENCODE_SERVER_PORT=7777
